# ── Motor LLM ─────────────────────────────────────────────────────────────
# Formato "proveedor:modelo" (lo interpreta init_chat_model de LangChain),
# o la palabra "fake" para jugar sin ningún LLM.
#
# Opción 1 — Anthropic (la mejor actuación; necesita API key):
DETECTIVE_MODEL=anthropic:claude-opus-4-8
ANTHROPIC_API_KEY=sk-ant-...
#
# Variantes más baratas de Anthropic (misma key):
#   DETECTIVE_MODEL=anthropic:claude-sonnet-5
#   DETECTIVE_MODEL=anthropic:claude-haiku-4-5
#
# Opción 2 — Ollama local (gratis; requiere `ollama serve` y un modelo bajado,
# mirá los tuyos con `ollama list`):
#   DETECTIVE_MODEL=ollama:llama3.1:8b
#
# Opción 3 — Sin nada (respuestas enlatadas, para probar la mecánica):
#   DETECTIVE_MODEL=fake

# ── Interfaz web (uv run detective-web) ───────────────────────────────────
# Puerto del servidor y archivo SQLite donde viven las partidas guardadas.
# Los defaults andan bien; descomentá solo si necesitás cambiarlos.
#   DETECTIVE_WEB_PORT=8765
#   DETECTIVE_DB=partidas.sqlite
